# broke — Vite 빌드 시 주입 (변경 후 dev 서버 재시작 또는 npm run build 다시)
# 끝 슬래시 없이 origin까지만 (경로 붙이지 않음)

# 백엔드 API 베이스
# 개발(npm run dev): 비우거나 생략 → 브라우저는 :5173만 사용, Vite가 127.0.0.1:8001로 프록시(/__gourmet_api__)
#   (공인IP:8001 직접 호출·집 안 NAT 루프백 실패를 피함. 포트포워딩은 5173만 열어도 됨)
# npm run build / preview: 반드시 브라우저가 직접 부를 수 있는 API URL (예: http://공인IP:8001)
# GOURMET_API_PROXY_TARGET — 선택, Vite 프록시 대상(기본 http://127.0.0.1:8001)
VITE_API_BASE_URL=

# 카카오 개발자 콘솔 — JavaScript 키 (지도). REST 키와 바꿔 쓰면 안 됨.
VITE_KAKAO_MAP_APP_KEY=

# 장소 키워드 검색 등 REST API
VITE_KAKAO_REST_API_KEY=

# 선택: 로컬에서 관리자 메뉴 전부 보기
# VITE_ASSUME_ADMIN_UI=1
