DATABASE_URL=postgresql://postgres:your_password@localhost:5432/brogourmet
# 다른 PC(또는 Docker)의 Postgres에 붙을 때 "UnicodeDecodeError" / 연결 실패면:
#  - 서버 postgresql.conf: listen_addresses = '*'
#  - 서버 pg_hba.conf: 앱이 나오는 IP 대역 허용 (예) host all all 192.168.0.0/16 scram-sha-256
#  - 방화벽에서 5432
#  - gourmet/requirements.txt 는 psycopg(3) 사용 — pip install -r requirements.txt 다시
# 가입된 계정을 매 부팅 시 super_admin 으로 맞춤(기본 2corea@gmail.com). 비우면 기본값 사용.
SUPER_ADMIN_EMAIL=2corea@gmail.com
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 이메일 인증: 가입 시 DB에는 토큰 해시만 저장. 개발 중 응답에 평문 토큰을 넣으려면 true.
DEV_RETURN_EMAIL_VERIFICATION_TOKEN=false
# true면 이메일 인증 완료 전 로그인(토큰 발급) 거부.
REQUIRE_EMAIL_VERIFIED_FOR_LOGIN=false
# 인증 링크 만료(시간). 기본 48.
EMAIL_VERIFICATION_EXPIRE_HOURS=48
# 선택. 없으면 JWT_SECRET_KEY를 pepper로 사용.
# EMAIL_VERIFY_PEPPER=

# POST /auth/resend-verification 는 스팸 방지·레이트 리밋은 운영에서 별도 적용 권장.

# --- 1단계 배포: true 이면 공개 API 가 허용 구만 노출 (broke 는 VITE_BROG_FULL_MAP 미설정 시 UI 도 동일 25구) ---
DEPLOY_STAGE1=true
# 비우면 기본 서울 25개 자치구(broke `data/regions.ts` `seoulDistricts` 와 동일 순서). 바꾸려면 쉼표로 구 이름 나열.
# DEPLOY_STAGE1_DISTRICT_NAMES=마포구,용산구,서대문구

# --- 운영: 가입 시 인증 메일을 반드시 보낸 뒤에만 계정 확정(실패 시 DB 롤백) ---
# true: flush 후 SMTP 동기 발송 → 성공 시 commit. false: 예전처럼 백그라운드 발송(설정 없으면 메일 없이 가입만 됨).
REQUIRE_VERIFICATION_EMAIL_ON_SIGNUP=true

# SMTP (Gmail: 앱 비밀번호 사용). REQUIRE_VERIFICATION_EMAIL_ON_SIGNUP=true 이면 반드시 유효해야 함.
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
# 465 SSL만 쓸 때: SMTP_USE_SSL=true, SMTP_PORT=465, SMTP_STARTTLS=false
# SMTP_USE_SSL=false
SMTP_USER=2corea@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=2corea@gmail.com
# 인증 링크에 쓰는 프론트 베이스 URL (끝 슬래시 없음)
FRONTEND_PUBLIC_URL=http://localhost:5173
# true면 발송 예외 시 API까지 전파(기본은 로그만)
# SMTP_FAIL_RAISES=false

# 지역 담당(regional_manager) 수동 배정 SQL → 저장소 루트 sql/ (설명 포함)
#   sql/list_districts.sql, sql/assign_regional_manager.sql

# --- 업로드 저장소 (BroG vs MyG·무료나눔) ---
# 로컬 전용: 미설정 시 gourmet/uploads/brog, gourmet/uploads/myg, 평면 레거시는 gourmet/uploads
# 1단계 배포 전 BroG만 서버(UNC/NAS)로: BROG_UPLOAD_DIR=\\서버\공유\brog
# MyG·무료나눔은 로컬 유지 권장: MYG_UPLOAD_DIR (기본 gourmet/uploads/myg)
# BROG_UPLOAD_DIR=
# MYG_UPLOAD_DIR=
# 레거시 평면 URL /uploads/{파일} — 구 DB·NAS 평면. 미설정 시 COMMUNITY_IMAGE_DIR 또는 gourmet/uploads
# UNC(예: \\192.168.x.x\공유)는 해당 PC가 켜져 있고 공유에 접근 가능할 때만 기동됩니다. 끊기면 WinError 53 등으로 uvicorn 이 실패합니다.
# LEGACY_UPLOAD_DIR=
# COMMUNITY_IMAGE_DIR=

# --- CORS (인터넷·Vercel·ngrok 등 프론트가 LAN이 아닐 때 필수) ---
# 로컬·LAN: http://127.0.0.1:5173, http://localhost:5173, http://192.168.*.*:5173 은 코드에 기본 허용.
# 공유기로 공인 IP:5173 접속 시 Origin 이 http://공인IP:5173 이라 192.168 정규식에 안 걸림 → 아래 둘 중 하나:
#   (A) BROG_CORS_EXTRA_ORIGINS=http://YOUR_WAN_IP:5173  (끝 슬래시 없음)
#   (B) 임시 서버용: BROG_CORS_WAN_HTTP_DEV=true  → http://아무IPv4:5173|4173 허용(운영 공개에는 비권장)
# 그 외 origin(HTTPS, ngrok 등)은 BROG_CORS_EXTRA_ORIGINS 에 정확히 나열(쉼표 구분).
# BROG_CORS_EXTRA_ORIGINS=https://your-app.vercel.app,https://abcd-123.ngrok-free.app
# 운영(별 도메인 프론트): 예) BROG_CORS_EXTRA_ORIGINS=https://bro.2corea.com — 브라우저 Origin과 문자열이 정확히 같아야 함(끝 슬래시 없음).
# BROG_CORS_WAN_HTTP_DEV=false
#
# 인터넷으로 열기 전 체크리스트:
# 1) 위에 프론트 접속 origin 추가 → gourmet 재시작
# 2) FRONTEND_PUBLIC_URL = 사용자가 브라우저로 여는 프론트 주소와 동일 (인증 메일 링크)
# 3) broke/.env 의 VITE_API_BASE_URL = 공개 백엔드 베이스 → npm run dev 재시작 또는 build 다시
# 4) 카카오 콘솔 Web·JS SDK 도메인에 위 프론트 origin 등록 (LAN과 URL이 다르면 각각)
# 5) 공유기 포트포워딩으로 PC를 직접 노출하기보다 ngrok 등 터널이 임시 테스트에 유리

# --- NHN KCP 표준결제 (모바일 거래등록 + Ret_URL + 서버 승인) — 선택 ---
# 문서: https://developer.kcp.co.kr/page/document/standardpay
# KCP_SITE_CD=
# 거래등록·승인에 쓰는 서비스 인증서 PEM 본문(줄바꿈은 \n 로 이어붙여도 됨)
# KCP_CERT_INFO=
# 또는 파일 경로(PEM)
# KCP_CERT_INFO_PATH=
# KCP가 인증 후 브라우저가 POST 하는 gourmet 공개 URL (끝 슬래시 없이 /payments/kcp/return 까지)
# 예: https://api.example.com/payments/kcp/return  — 로컬만이면 ngrok 등 터널 URL
# BROG_KCP_RETURN_URL=
# 테스트(기본) / 운영 전환 시 true
# KCP_LIVE=false
# 승인 API pay_type (카드 예: PACA). 미설정 시 PACA
# KCP_PAY_TYPE=PACA
# 결제창에 표시할 상점명
# KCP_SHOP_NAME=BroGourmet
# 엔드포인트 덮어쓰기(미설정 시 문서 기본 테스트 URL)
# KCP_REGISTER_URL=
# KCP_PAYMENT_URL=

# --- CLOVA OCR (General, 메뉴판 등 — 선택) ---
# NCP 콘솔에서 발급한 Invoke URL(…/general 까지)과 Secret. 미설정 시 /ocr/clova/* 는 503.
# CLOVA_OCR_INVOKE_URL=https://xxxx.apigw.ntruss.com/custom/v1/.../general
# CLOVA_OCR_SECRET_KEY=
# 선택. 초과 시 조정(초).
# CLOVA_OCR_TIMEOUT_SECONDS=90
